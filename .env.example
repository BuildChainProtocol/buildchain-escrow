# ─── NETWORK ──────────────────────────────────────────────────────
XRPL_NETWORK=testnet
XRPL_TESTNET_URL=wss://s.altnet.rippletest.net:51233
XRPL_MAINNET_URL=wss://xrplcluster.com

# ─── REGISTRY ─────────────────────────────────────────────────────
REGISTRY_PATH=./data/escrow-registry.json

# ─── PROTOCOL CONFIG ──────────────────────────────────────────────
DEFAULT_FINISH_AFTER_HOURS=1
DEFAULT_ESCROW_WINDOW_DAYS=90
PROTOCOL_FEE_BPS=30

# ─── WALLET SEEDS (set by setup-testnet.ts or manually) ──────────
LENDER_WALLET_SEED=
GC_WALLET_SEED=
PROTOCOL_WALLET_SEED=
INSPECTOR_ISSUER_SEED=
RLUSD_ISSUER_SEED=

# ─── WALLET ADDRESSES ─────────────────────────────────────────────
LENDER_WALLET_ADDRESS=
GC_WALLET_ADDRESS=
PROTOCOL_WALLET_ADDRESS=
INSPECTOR_ISSUER_ADDRESS=
RLUSD_ISSUER_ADDRESS=

# ─── RLUSD CONFIG ─────────────────────────────────────────────────
RLUSD_TRUST_LIMIT=1000000

# ─── DEMO CONFIG ──────────────────────────────────────────────────
DEMO_FINISH_AFTER_MINUTES=2
DEMO_PROJECT_ID=BLDCHN-DEMO-001
